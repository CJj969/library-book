@using LibrarySeatReservation.Web.Models.ViewModels
@using LibrarySeatReservation.Web.Services
@model AdminReservationsViewModel
@{
    ViewData["Title"] = "预约管理";
}

<div class="container-fluid px-4">
    <h4 class="mb-4">预约管理</h4>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-auto">
                    <label class="form-label small">状态</label>
                    <select name="statusFilter" class="form-select form-select-sm" style="min-width:120px;">
                        <option value="">全部</option>
                        <option value="已预约" selected="@(Model.StatusFilter == "已预约")">已预约</option>
                        <option value="已取消" selected="@(Model.StatusFilter == "已取消")">已取消</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small">日期</label>
                    <input type="date" name="dateFilter" class="form-control form-control-sm" value="@Model.DateFilter?.ToString("yyyy-MM-dd")" style="min-width:160px;" />
                </div>
                <div class="col-auto">
                    <label class="form-label small">区域</label>
                    <select name="areaFilter" class="form-select form-select-sm" style="min-width:140px;">
                        <option value="">全部</option>
                        @foreach (var area in Model.Areas)
                        {
                            <option value="@area" selected="@(Model.AreaFilter == area)">@area</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm">筛选</button>
                    <a asp-controller="Admin" asp-action="Reservations" class="btn btn-outline-secondary btn-sm ms-1">重置</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>用户</th>
                        <th>座位</th>
                        <th>区域</th>
                        <th>日期</th>
                        <th>时段</th>
                        <th>状态</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Reservations.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">暂无预约记录</td>
                        </tr>
                    }
                    @foreach (var item in Model.Reservations)
                    {
                        <tr>
                            <td>@item.UserName</td>
                            <td>@item.SeatNumber</td>
                            <td>@item.Area</td>
                            <td>@item.ReserveDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.TimeSlot</td>
                            <td>
                                @if (item.Status == "已预约")
                                {
                                    <span class="badge" style="background-color:#EFF6FF;color:#2563EB;">已预约</span>
                                }
                                else if (item.Status == "已取消")
                                {
                                    <span class="badge" style="background-color:#FEF2F2;color:#DC2626;">已取消</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Status</span>
                                }
                            </td>
                            <td>
                                @if (item.CanCancel)
                                {
                                    <form asp-controller="Admin" asp-action="CancelReservation" method="post" style="display:inline;"
                                          onsubmit="return confirm('确定取消 @item.UserName 的 @item.SeatNumber @item.TimeSlot 预约？');">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">取消预约</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">--</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
