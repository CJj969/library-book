@using LibrarySeatReservation.Web.Services
@using LibrarySeatReservation.Web.Models.ViewModels
@model List<SeatAdminItem>
@{
    ViewData["Title"] = "座位管理";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">座位管理</h4>
        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createModal">+ 新增座位</button>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>编号</th>
                        <th>区域</th>
                        <th>描述</th>
                        <th>状态</th>
                        <th>关联预约</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">暂无座位数据</td>
                        </tr>
                    }
                    @foreach (var seat in Model)
                    {
                        <tr>
                            <td>@seat.SeatNumber</td>
                            <td>@seat.Area</td>
                            <td>@seat.Description</td>
                            <td>
                                @if (seat.IsActive)
                                {
                                    <span class="badge" style="background-color:#ECFDF5;color:#059669;">启用</span>
                                }
                                else
                                {
                                    <span class="badge" style="background-color:#FFFBEB;color:#D97706;">维修中</span>
                                }
                            </td>
                            <td>
                                <span class="text-muted small">@seat.ReservationCount 条</span>
                            </td>
                            <td>
                                <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="modal"
                                        data-bs-target="#editModal"
                                        data-id="@seat.Id"
                                        data-number="@seat.SeatNumber"
                                        data-area="@seat.Area"
                                        data-desc="@seat.Description">编辑</button>

                                <form asp-controller="Admin" asp-action="ToggleSeatStatus" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@seat.Id" />
                                    <button type="submit" class="btn btn-outline-warning btn-sm">
                                        @(seat.IsActive ? "设为维修" : "启用")
                                    </button>
                                </form>

                                <form asp-controller="Admin" asp-action="DeleteSeat" method="post" style="display:inline;"
                                      onsubmit="return confirm('确定删除座位 @seat.SeatNumber 吗？');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@seat.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">删除</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Admin" asp-action="CreateSeat" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">新增座位</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">座位编号</label>
                        <input name="SeatNumber" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">区域</label>
                        <input name="Area" class="form-control" required placeholder="如：2楼A区" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">描述</label>
                        <input name="Description" class="form-control" placeholder="如：靠窗、有插座" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-primary">保存</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Admin" asp-action="EditSeat" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editId" />
                <div class="modal-header">
                    <h5 class="modal-title">编辑座位</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">座位编号</label>
                        <input name="SeatNumber" id="editNumber" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">区域</label>
                        <input name="Area" id="editArea" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">描述</label>
                        <input name="Description" id="editDesc" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-primary">保存</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var editModal = document.getElementById('editModal');
        if (editModal) {
            editModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                document.getElementById('editId').value = button.getAttribute('data-id');
                document.getElementById('editNumber').value = button.getAttribute('data-number');
                document.getElementById('editArea').value = button.getAttribute('data-area');
                document.getElementById('editDesc').value = button.getAttribute('data-desc');
            });
        }
    </script>
}
