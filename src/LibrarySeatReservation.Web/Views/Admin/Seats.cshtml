@using LibrarySeatReservation.Web.Services
@model List<SeatAdminItem>
@{
    ViewData["Title"] = "座位管理";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">座位管理</h4>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>编号</th>
                        <th>区域</th>
                        <th>描述</th>
                        <th>状态</th>
                        <th>关联预约</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">暂无座位数据</td>
                        </tr>
                    }
                    @foreach (var seat in Model)
                    {
                        <tr>
                            <td>@seat.SeatNumber</td>
                            <td>@seat.Area</td>
                            <td>@seat.Description</td>
                            <td>
                                @if (seat.IsActive)
                                {
                                    <span class="badge" style="background-color:#ECFDF5;color:#059669;">启用</span>
                                }
                                else
                                {
                                    <span class="badge" style="background-color:#FFFBEB;color:#D97706;">维修中</span>
                                }
                            </td>
                            <td>
                                <span class="text-muted small">@seat.ReservationCount 条</span>
                            </td>
                            <td>
                                <span class="text-muted small">待实现</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
