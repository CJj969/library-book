@model ErrorViewModel
@{
    var is404 = Model.StatusCode == 404;
    ViewData["Title"] = is404 ? "页面未找到" : "出错了";
}

<div class="text-center py-5" style="max-width:480px;margin:0 auto;">
    <div class="display-1 fw-bold text-muted mb-3">@(is404 ? "404" : "500")</div>
    <h4 class="mb-3">@(is404 ? "页面未找到" : "服务出错了")</h4>
    <p class="text-muted mb-4">
        @(is404
            ? "您访问的页面不存在，请检查网址是否正确"
            : "服务器遇到了一些问题，请稍后重试")
    </p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4" style="border-radius:8px;">
        回到首页
    </a>
</div>
